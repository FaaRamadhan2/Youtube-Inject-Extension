{
  "manifest_version": 3,
  "name": "YouTube Focus Anti Pause Combo",
  "version": "13.0.1",
  "description": "Focus mode, YouTube theme injection, channel page styling, wallpaper, ad cleanup, and safe continue-watching clicker.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "action": {
    "default_title": "YouTube Focus Combo",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
